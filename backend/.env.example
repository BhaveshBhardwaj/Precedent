# LLM provider key (OpenAI, Anthropic, etc. — any Cognee-supported provider)
LLM_API_KEY=sk-...

# Cognee mode: "local" for embedded (SQLite+LanceDB+Kuzu), "cloud" for Cognee Cloud
COGNEE_MODE=local

# Only needed if COGNEE_MODE=cloud
COGNEE_API_URL=
COGNEE_API_TOKEN=

# App database (SQLite for lightweight app state)
DATABASE_URL=sqlite:///./precedent.db
